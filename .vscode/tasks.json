{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Decrypt and open JSON",
      "type": "shell",
      "command": "python3 decrypt_lausepank.py && code lausepank-andmed.json",
      "options": {
        "env": {
          "MALLID_PASSWORD": "${input:password}"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Validate JSON",
      "type": "shell",
      "command": "python3 -m json.tool lausepank-andmed.json > /dev/null",
      "problemMatcher": []
    },
    {
      "label": "Format JSON",
      "type": "shell",
      "command": "python3 -m json.tool lausepank-andmed.json > lausepank-andmed.tmp && mv lausepank-andmed.tmp lausepank-andmed.json",
      "problemMatcher": []
    },
    {
      "label": "Encrypt lausepank-andmed.json",
      "type": "shell",
      "command": "python3 encrypt_lausepank.py",
      "options": {
        "env": {
          "MALLID_PASSWORD": "${input:password}"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Safe Encrypt",
      "dependsOn": [
        "Validate JSON",
        "Format JSON",
        "Encrypt lausepank-andmed.json"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "password",
      "type": "promptString",
      "description": "Enter encryption password",
      "password": true
    }
  ]
}
